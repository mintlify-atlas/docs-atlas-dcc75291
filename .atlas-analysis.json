  "keyFeatures": [
    "Annual Work Plan (PTA) creation and management",
    "User authentication and role-based access control",
    "Department and position management",
    "Indicators and actions tracking",
    "Email notifications for password recovery and welcome messages",
    "Admin dashboard with CRUD operations",
    "Multi-level approval workflow (supervisor and aval)",
    "Progress tracking and reporting"
