    "Encabezado entity (PTA header management)",
    "Personal entity (staff management)",
    "User entity (authentication)",
    "Indicadores entity (performance indicators)",
    "Acciones entity (action items)",
    "Departamento entity (department structure)",
    "Puesto entity (position/role)",
    "EncabezadoController (PTA CRUD operations)",
    "PersonalController (staff management)",
    "SecurityController (authentication)",
    "UserCreator service",
    "WelcomeMailer service",
    "RecuperarPasswordMailer service"
